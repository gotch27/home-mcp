# Copy this file to .env.local for local development.
# In production, set these variables in Vercel Project Settings.
# All app-owned env vars must use the prefix from nextsignal/config.ts: NEXTSIGNAL_.
#
# NextSignal maps double underscores to config paths:
# NEXTSIGNAL_DATABASE__URL -> database.url

# Use `production` for this value in Vercel's Production environment.
NEXTSIGNAL_APP__ENVIRONMENT=local
NEXTSIGNAL_LOGGING__LEVEL=debug
NEXTSIGNAL_LOGGING__RETENTIONDAYS=3

NEXTSIGNAL_DATABASE__URL=postgres://user:password@localhost:5432/home
NEXTSIGNAL_DATABASE__SSL=false
NEXTSIGNAL_DATABASE__MAXCONNECTIONS=3

NEXTSIGNAL_NOTIFICATIONS__FROM__NAME=Home MCP
NEXTSIGNAL_NOTIFICATIONS__FROM__EMAIL=home@example.com

NEXTSIGNAL_EMAIL__SMTP__HOST=smtp-relay.brevo.com
NEXTSIGNAL_EMAIL__SMTP__PORT=587
NEXTSIGNAL_EMAIL__SMTP__SECURE=false
NEXTSIGNAL_EMAIL__SMTP__USER=
NEXTSIGNAL_EMAIL__SMTP__PASS=

NEXTSIGNAL_MAINTENANCE__CRONSECRET=
NEXTSIGNAL_WORKER__ENABLED=false
