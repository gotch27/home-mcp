# This file should cover every empty field in config/default.json plus any
# config/default.json field that is intentionally environment-specific.

# Nested config keys use double underscores:
# example: NEXTSIGNAL_DATABASE__URL=postgres://user:password@localhost:5432/home

# MCP OAuth resource server configuration.
NEXTSIGNAL_MCP__RESOURCEURL=https://your-public-domain.example.com/api/mcp
NEXTSIGNAL_WORKOS__AUTHKITDOMAIN=https://your-subdomain.authkit.app

# WorkOS browser session configuration.
NEXTSIGNAL_WORKOS__CLIENTID=client_your_client_id
NEXTSIGNAL_WORKOS__APIKEY=sk_test_your_api_key
NEXTSIGNAL_WORKOS__COOKIEPASSWORD=generate_at_least_32_characters
NEXTSIGNAL_WORKOS__REDIRECTURI=http://localhost:3000/callback
